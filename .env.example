# ---------------------------------------------------------------- Database
# Supabase: DATABASE_URL is the pooled (pgbouncer) connection used by the app.
# DIRECT_URL is the direct connection, used only to run migrations.
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:pass@host:5432/postgres"
# Optional. Only set by the integration tests, which truncate tables.
# DATABASE_SCHEMA="test"

# ---------------------------------------------------------------- Auth.js
# openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# -------------------------------------------------- Google (login + YouTube)
# One OAuth client covers both. Signing in requests only `openid email profile`;
# `youtube.readonly` is requested separately by the connect flow.
#
# Authorized redirect URIs to register in Google Cloud Console:
#   http://localhost:3000/api/auth/callback/google
#   http://localhost:3000/api/connect/youtube/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------- TikTok
# TikTok calls it a client KEY, not a client id.
# Needs a developer app with Login Kit + Display API, and `video.list` approved.
# Redirect URI to register:
#   http://localhost:3000/api/connect/tiktok/callback
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# -------------------------------- Instagram (API with Instagram Login)
# NOT the legacy Facebook-Login variant, which also demands a linked FB Page.
# Requires a Business or Creator account.
# Redirect URI to register:
#   http://localhost:3000/api/connect/instagram/callback
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# ------------------------------------------------------- Token encryption
# 32 random bytes, base64:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=""

# ------------------------------------------------------------- Vercel Cron
# Vercel sends this as `Authorization: Bearer <CRON_SECRET>` on scheduled runs.
CRON_SECRET=""

# ---------------------------------------------------------------- App
# Used to build OAuth redirect URIs. Must match the deployed origin exactly.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
