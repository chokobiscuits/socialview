# Integration tests truncate tables. They run against an isolated `test` schema
# in the local Postgres, so they can never touch your development data.
#
# Set it up once with: npm run db:test:setup
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
DIRECT_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
DATABASE_SCHEMA="test"

